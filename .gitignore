# ── Node / Vite ──────────────────────────────────────────────
node_modules/
dist/
.vite/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.eslintcache

# ── Tauri / Rust ─────────────────────────────────────────────
src-tauri/target/
# Generated schemas/capabilities committed via `gen/schemas/*.json`
# are tracked explicitly only when needed for inspection; safe to ignore.
src-tauri/gen/schemas/

# ── IDE / OS ────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
*~

# ── Local test / scratch ─────────────────────────────────────
sessions.csv
*.tmp
*.bak
HANDOFF.md

# ── Vendored sub-repos (have their own git history) ─────────
vendored/cursaves/
vendored/cursor-history/

# ── Python (legacy daemon code & tests, kept for reference) ──
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# ── Reference media (kept out of repo) ──────────────────────
# Uncomment if the screenshot is treated as binary asset
# cc-switch-session.png

# ── Secrets / env (would otherwise leak API keys) ──────────
.env
.env.*
!.env.example

# ── Test coverage output (vitest --coverage / tarpaulin) ──
coverage/
*.lcov
*.lcov.info

# ── OS additions (resource forks / Office locks) ───────────
.AppleDouble
._*
desktop.ini
ehthumbs.db
~$*
nohup.out

# ── Defense against accidental alternative lockfiles ───────
package-lock.json
yarn.lock
